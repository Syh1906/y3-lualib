{
    "workspace.preloadFileSize": 5000,
    "runtime.path": [
        "?.lua",
        "?/init.lua",
        "../../../global_script/?.lua",
        "../../../global_script/?/init.lua"
    ],
    "diagnostics.ignoredFiles": "Disable",
    "runtime.version": "Lua 5.4",
    "runtime.pathStrict": true,
    "runtime.special": {
        "include": "require"
    },
    "workspace.library": [
        "../../../global_script"
    ],
    "workspace.ignoreDir": [
        "y3/演示",
        "y3/testcase",
        "y3/unittest"
    ],
    "hover.expandAlias": false,
    "doc": {
		"packageName": [
			"pk_*"
		],
		"privateName": [
			"pr_*",
            "__*"
		],
		"protectedName": [
			"pt_*"
		]
	},
    "diagnostics.groupFileStatus": {
        "ambiguity": "Any",
        "await": "Any",
        "duplicate": "Any",
        "global": "Any",
        "luadoc": "Any",
        "redefined": "Any",
        "strict": "Any",
        "type-check": "Any",
        "unbalanced": "Any",
        "unused": "Any"
    },
    "type.weakNilCheck": false,
    "type.weakUnionCheck": false,
    "type.castNumberToInteger": false,
    "runtime.unicodeName": true
}